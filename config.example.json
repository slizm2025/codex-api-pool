{
  "server": {
    "host": "127.0.0.1",
    "port": 8787,
    "public_prefix": "/v1",
    "auth_token_env": "CODEX_POOL_API_KEY",
    "max_body_bytes": 52428800,
    "request_timeout_ms": 180000,
    "graceful_shutdown_ms": 15000,
    "admin_auth_token_env": ""
  },
  "model_override": "",
  "compatibility": {
    "adapter_mode": {
      "strip_responses_only_features": false,
      "adapters": {
        "anthropic_messages": true,
        "chat_completions": true
      }
    }
  },
  "retry": {
    "max_attempts": 4,
    "failure_threshold": 2,
    "base_cooldown_ms": 30000,
    "key_cooldown_ms": 60000,
    "chat_fallback_probe_timeout_ms": 15000,
    "native_responses_recheck_ms": 1800000,
    "retryable_statuses": [400, 401, 403, 404, 408, 409, 425, 429, 500, 502, 503, 504, 521, 522, 523, 524]
  },
  "availability": {
    "window_size": 50,
    "min_samples": 10,
    "boost_threshold": 0.95,
    "healthy_threshold": 0.9,
    "degraded_threshold": 0.75,
    "poor_threshold": 0.5
  },
  "upstreams": [
    {
      "name": "rawchat",
      "api": "openai",
      "base_url": "https://new.sharedchat.cc/codex",
      "weight": 3,
      "keys": [
        {
          "env": "RAWCHAT_API_KEY"
        }
      ],
      "billing": {
        "enabled": true,
        "base_url": "https://new.sharedchat.cc",
        "subscription_path": "/dashboard/billing/subscription",
        "usage_path": "/dashboard/billing/usage?start_date={start_date}&end_date={end_date}",
        "currency": "USD",
        "large_limit_threshold": 10000000,
        "trust_large_limits": false
      }
    },
    {
      "name": "sub2codex",
      "api": "openai",
      "base_url": "https://muyuan.do/v1",
      "weight": 2,
      "keys": [
        {
          "env": "SUB2API_API_KEY"
        }
      ]
    },
    {
      "name": "blackandwhilt",
      "api": "openai",
      "base_url": "https://api.42w.shop/v1",
      "weight": 1,
      "keys": [
        {
          "env": "BLACK_API_KEY"
        }
      ]
    },
    {
      "name": "runanytime_claude",
      "api": "anthropic",
      "base_url": "https://runanytime.example",
      "health_path": "/v1/models",
      "probe_auth": "anthropic",
      "model_suffix_strip": "-cc",
      "weight": 1,
      "keys": [
        {
          "env": "RUN_CLAUDE_API_KEY"
        }
      ]
    }
  ],
  "health": {
    "enabled": false,
    "interval_ms": 60000,
    "timeout_ms": 10000,
    "concurrency": 4,
    "path": "/models"
  },
  "billing": {
    "timeout_ms": 10000,
    "concurrency": 3
  },
  "stats": {
    "path": "stats.local.json"
  }
}
